{
  "realm": "dev",
  "enabled": true,
  "verifyEmail": false,
  "registrationAllowed": true,
  "resetPasswordAllowed": false,
  "clientScopes": [
    {
      "name": "profile",
      "protocol": "openid-connect"
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect"
    },
    {
      "name": "audience",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "ghibli-client",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "ghibli-client",
      "secret": "ghibli-secret",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "audience"
      ],
      "redirectUris": [
        "http://localhost:4000/oauth2/callback"
      ]
    }
  ],
  "users": [
    {
      "username": "test-user",
      "enabled": true,
      "email": "test@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}