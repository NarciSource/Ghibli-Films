{
  "realm": "dev",
  "displayName": "Ghibli Best Cuts",
  "enabled": true,
  "loginTheme": "keycloakify-ghibli",
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "ko"],
  "defaultLocale": "ko",
  "verifyEmail": false,
  "registrationAllowed": true,
  "resetPasswordAllowed": false,
  "roles": {
    "client": {
      "ghibli-client": [
        {
          "name": "user"
        },
        {
          "name": "admin"
        }
      ]
    }
  },
  "clientScopes": [
    {
      "name": "profile",
      "protocol": "openid-connect"
    },
    {
      "name": "username",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "clientId": "ghibli-client",
            "rolePrefix": "",
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "audience",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "ghibli-client",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "ghibli-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "defaultClientScopes": [
        "profile",
        "username",
        "email",
        "roles",
        "audience"
      ],
      "redirectUris": [
        "http://localhost:8080/oauth2/callback"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "emailVerified": true,
      "firstName": "admin",
      "lastName": "admin",
      "clientRoles": {
        "ghibli-client": [
          "admin"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "pswd",
          "temporary": false
        }
      ]
    },
    {
      "username": "test-user",
      "enabled": true,
      "email": "test@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "clientRoles": {
        "ghibli-client": [
          "user"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}